FROM nvidia/cuda:12.8.1-devel-ubuntu22.04

ARG DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
    bash \
    ca-certificates \
    clang \
    rapidjson-dev \
    clang-tools \
    clangd-14 \
    curl \
    freeglut3-dev \
    git \
    libc++-dev \
    libc++abi-dev \
    libegl1 \
    libgl1 \
    libgl1-mesa-dev \
    libglu1-mesa-dev \
    libglib2.0-0 \
    libopengl-dev \
    libx11-dev \
    libxcursor-dev \
    libxext-dev \
    libxi-dev \
    libxinerama-dev \
    libxrandr-dev \
    libvulkan1 \
    lld \
    ninja-build \
    pkg-config \
    python3 \
    python3-dev \
    python3-pip \
    python3-venv \
    sudo \
    zsh \
    && rm -rf /var/lib/apt/lists/* \
    && ln -sf /usr/bin/clangd-14 /usr/bin/clangd

# Locale + virtual desktop for SAPIEN (sapien/readme.md: xvfb, x11vnc, fluxbox)
RUN apt-get update \
    && apt-get install -y --no-install-recommends locales \
    && sed -i '/en_US.UTF-8/s/^# *//' /etc/locale.gen \
    && locale-gen \
    && apt-get install -y --no-install-recommends software-properties-common \
    && add-apt-repository -y universe \
    && apt-get update \
    && apt-get install -y --no-install-recommends \
        openbox \
        xterm \
        xvfb \
        x11vnc \
        fluxbox \
    && rm -rf /var/lib/apt/lists/*

# Ensure Vulkan/EGL ICD manifests are available for SAPIEN detection in container.
# NVIDIA driver libs are provided by nvidia-container-runtime (e.g. libGLX_nvidia.so.0).
RUN mkdir -p /usr/share/vulkan/icd.d /usr/share/glvnd/egl_vendor.d \
    && printf '%s\n' \
      '{' \
      '  "file_format_version": "1.0.0",' \
      '  "ICD": {' \
      '    "library_path": "libGLX_nvidia.so.0",' \
      '    "api_version": "1.3.224"' \
      '  }' \
      '}' > /usr/share/vulkan/icd.d/nvidia_icd.json \
    && printf '%s\n' \
      '{' \
      '  "file_format_version": "1.0.0",' \
      '  "ICD": {' \
      '    "library_path": "libEGL_nvidia.so.0"' \
      '  }' \
      '}' > /usr/share/glvnd/egl_vendor.d/10_nvidia.json

# Oh My Zsh (dev-setup omz.sh: https://github.com/deskchen/dev-setup)
ARG OMZ_DIR=/tmp/omz-setup
RUN mkdir -p "${OMZ_DIR}" \
    && curl -fsSL https://raw.githubusercontent.com/deskchen/dev-setup/main/omz.sh -o "${OMZ_DIR}/omz.sh" \
    && curl -fsSL https://raw.githubusercontent.com/deskchen/dev-setup/main/personal.zsh-theme -o "${OMZ_DIR}/personal.zsh-theme" \
    && chmod +x "${OMZ_DIR}/omz.sh" \
    && cd "${OMZ_DIR}" && bash omz.sh \
    && rm -rf "${OMZ_DIR}"

# CMake 3.26.3 — need >= 3.24 (sapien-vulkan-2) but < 4.0 (zlib 1.2.11 compat).
ARG CMAKE_VERSION=3.26.3
RUN curl -fsSL "https://github.com/Kitware/CMake/releases/download/v${CMAKE_VERSION}/cmake-${CMAKE_VERSION}-linux-x86_64.tar.gz" \
    | tar xz -C /usr/local --strip-components=1

# Allow git to operate on bind-mounted workspace directories owned by host user.
RUN git config --global --add safe.directory '*'

# PyTorch for Meta-World Franka tasks (GPU drive targets via PhysX Direct GPU API).
RUN pip3 install --no-cache-dir torch

ENV CC=clang
ENV CXX=clang++
ENV CUDA_PATH=/usr/local/cuda
ENV CMAKE_GENERATOR=Ninja
ENV NVIDIA_DRIVER_CAPABILITIES=graphics,utility,compute,display
ENV LANG=en_US.UTF-8
ENV LC_ALL=en_US.UTF-8

WORKDIR /workspace
